# Gradle files
.gradle/
build/
*/build/
!gradle/wrapper/gradle-wrapper.jar
!**/build/*/classes/
!**/build/*/generated/

# Gradle wrapper (если вы используете wrapper, сам wrapper обычно хранят в репозитории)
gradle-wrapper.jar
gradle-wrapper.properties

# Local configuration file (sdk path, etc.)
local.properties

# Log/OS Files
*.log
*.lock
*.iml
*.iws
.idea/
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf
.idea/shelf/
.idea/**/gradle.xml
.idea/**/libraries
*.keystore
*.jks

# Android Studio captures folder
captures/

# Intellij
out/

# Keystore files (не коммитим)
*.jks
*.keystore

# Google Services (если используется, лучше не коммитить)
google-services.json

# Fastlane (если используется)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# Environment / Secrets
.env
secrets.properties

# macOS
.DS_Store

# Windows
Thumbs.db

# VS Code
.vscode/

# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# NDK
obj/

# Crashlytics (если используется)
crashlytics-build.properties

# Proguard (обычно конфиги хранят, но маппинги не нужно)
proguard/
*.mapping.txt

# Dependency directories (если используете локальные jar, можно оставить, но лучше через Gradle)
libs/
!**/libs/*.jar